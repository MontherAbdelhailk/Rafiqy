{
  "name": "rafiq-auth-backend",
  "version": "1.0.0",
  "description": "Production-ready Authentication Backend for Rafiq App",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/database/migrate.js",
    "db:migrate-3nf": "node src/database/migration_3nf.js",
    "db:seed": "node src/database/seed.js && node src/database/seed_all_slots.js",
    "db:seed-slots": "node src/database/seed_all_slots.js"
  },
  "keywords": [
    "auth",
    "jwt",
    "express",
    "postgresql"
  ],
  "author": "Rafiq Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pg": "^8.12.0",
    "pg-pool": "^3.6.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
