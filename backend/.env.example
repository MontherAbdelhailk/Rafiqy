# ============================
# Server Configuration
# ============================
NODE_ENV=development
PORT=5000

# ============================
# PostgreSQL Database
# ============================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rafiq_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ============================
# JWT Configuration
# ============================
JWT_SECRET=b4d7df11140c250c2a68c386f54f93affd64229bf0a34be85e6f77291f24ca22NT
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ============================
# Security
# ============================
BCRYPT_SALT_ROUNDS=12
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================
# Rate Limiting
# ============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ============================
# Paymob Integration
# ============================
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_CARD_INTEGRATION_ID=your_card_integration_id_here
PAYMOB_WALLET_INTEGRATION_ID=your_wallet_integration_id_here
PAYMOB_MEEZA_INTEGRATION_ID=your_meeza_integration_id_here
PAYMOB_IFRAME_ID=your_iframe_id_here
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret_here
PAYMOB_PUBLIC_KEY=your_paymob_public_key_here
PAYMOB_SECRET_KEY=your_paymob_secret_key_here
MAX_VIDEO_SIZE=314572800



